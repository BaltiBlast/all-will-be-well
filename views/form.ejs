<%- include('partials/head.ejs'); -%>

<div>
  <section class="title">
    <article class="tagline-bg shadow lato-bold">
      <p class="tagline lato-bold">Raconte où tu en es aujourd’hui,</p>
    </article>
    <p class="subline lato-thin">ton futur toi verra le <span class="lato-regular">chemin parcouru.</span></p>
  </section>

  <article class="grid counter">
    <p class="lato-light no-marge">Messages programmés : <span class="lato-bold"><%=messageWaiting%></span></p>
    <p class="lato-light no-marge">Messages envoyés : <span class="lato-bold"><%=sentMessageCount%></span></p>
  </article>

  <form id="formMessage" action="/add-message" method="POST">
    <article>
      <!-- FLASH MESSAGE -->
      <% if (messages && messages.length > 0) { %> <% messages.forEach(m => { %>
      <p class="<%= m.type %>-message"><%= m.text %></p>
      <% }) %> <% } %>
      <label>
        Prénom
        <input type="text" name="name" placeholder="Florian" required />
      </label>

      <label>
        Email
        <input type="email" name="email" placeholder="exemple@domaine.com" required />
      </label>

      <label>
        Quand veux-tu recevoir ton message ?
        <select name="delay" aria-label="Dans combien de temps veux-tu relire ce message ?" required>
          <option selected disabled value="">Séléctionne un délai...</option>
          <option value="3d">3 jours</option>
          <option value="1w">1 semaine</option>
          <option value="1m">1 mois</option>
          <option value="3m">3 mois</option>
        </select>
      </label>

      <label>
        Message <small id="char-counter">0 / 2000</small>
        <div class="textarea-wrapper">
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder=""
            maxlength="2000"
            minlength="10"
            required
          ></textarea>
          <span id="fake-placeholder"></span>
        </div>
      </label>

      <dialog id="confirmFormMessage">
        <article>
          <p>Chaque email ne peut être utilisé qu'une seule fois à la fois.</p>
          <p>Vous pourrez programmer un nouveau message uniquement après avoir reçu celui-ci.</p>
          <p>Voulez-vous envoyer ce message tel quel ?</p>
          <footer>
            <button id="messageFormClosedButton" type="button">Revoir</button>
            <button id="messageFormSubmitButton" type="button">Envoyer</button>
          </footer>
        </article>
      </dialog>
      <label class="recaptcha-wrapper">
        <div class="g-recaptcha" data-sitekey="<%= siteKey %>"></div>
      </label>
      <button type="submit">Envoyer !</button>
    </article>
  </form>
</div>

<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script type="module" src="/js/messageForm.script.js"></script>

<%- include('partials/footer.ejs'); -%>
